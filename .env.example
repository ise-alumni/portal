# ==============================================================================
# ISE Alumni Portal
# Copy to .env and fill in values: cp .env.example .env
# ==============================================================================

# Authentication (Better Auth)
# Generate a secret: openssl rand -base64 32
BETTER_AUTH_SECRET=your-secret-key-at-least-32-characters-long
BETTER_AUTH_URL=http://localhost:3000

# Database
# Local development uses an ephemeral SQLite file.
# Production uses a Turso cloud database.
#   Dev:  file:data.db
#   Prod: libsql://your-db-name.turso.io
DATABASE_URL=file:data.db
# Required for Turso cloud; leave blank for local SQLite.
TURSO_AUTH_TOKEN=

# Server
PORT=3000
CORS_ORIGIN=http://localhost:8080

# Frontend
VITE_API_URL=http://localhost:3000
VITE_MAPBOX_TOKEN=your_mapbox_token_here

# Logging (trace, debug, info, warn, error, silent)
VITE_LOG_LEVEL=info
